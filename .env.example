# Copy to .env (gitignored) and fill in. Never commit real keys.
# Leave GEMINI_API_KEY blank to run FULLY OFFLINE on the deterministic stub.

# ── LLM (Gemini) ──────────────────────────────────────────────
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
LLM_PROVIDER=auto                 # auto = Gemini if key present else stub | gemini | stub
GEMINI_MODEL=gemini-2.5-flash     # NOTE: free tier ~20 req/day per model. For recording a demo or
                                  # letting people test, enable billing on the Google Cloud project
                                  # (gemini-flash is very cheap). If quota is hit, the app auto-falls
                                  # back to the offline stub — it never crashes mid-demo.

# ── Embeddings ────────────────────────────────────────────────
# hash = offline, zero-dep (default)  |  gemini = true semantic recall (uses GEMINI_API_KEY)
EMBED_PROVIDER=hash

# ── Gmail draft on Approve (optional) ─────────────────────────
# On Approve, the drafted email is appended to your Gmail Drafts (draft only —
# never sends). Create an App Password: Google Account → Security → 2-Step
# Verification → App passwords. Ensure IMAP is on in Gmail settings.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_DRAFT_TO=                    # optional: where drafts are addressed (defaults to GMAIL_ADDRESS)
